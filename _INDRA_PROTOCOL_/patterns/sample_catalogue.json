{
  "id": "sample_catalogue",
  "name": "Standard Product & Service Catalogue",
  "class": "SCHEMA",
  "handle": {
    "alias": "Main Catalogue",
    "location": "src/components/ProductGrid.js",
    "selector": "#main-grid"
  },
  "protocols": ["PULL_SYNC", "ATOM_READ"],
  "properties": [
    {
      "name": "id",
      "type": "STRING",
      "silo_mapping": "EXTERNAL_ID"
    },
    {
      "name": "name",
      "type": "STRING",
      "silo_mapping": "TITLE"
    },
    {
      "name": "price",
      "type": "NUMBER",
      "silo_mapping": "UNIT_PRICE"
    },
    {
      "name": "image_url",
      "type": "URL",
      "silo_mapping": "ASSET_LINK"
    }
  ],
  "metadata": {
    "source_silo": "GENERIC_PROVIDER",
    "sync_mode": "READ_ONLY"
  }
}
